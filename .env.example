# Database (local Docker: docker compose up -d)
DATABASE_URL="postgresql://bluepearl:bluepearl@localhost:5432/bluepearl"

# Auth.js — keep AUTH_SECRET stable; changing it invalidates existing login cookies.
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CURRENCY="USD"

# WhatsApp contact (footer, floating button, product pages)
# PHONE: digits only for wa.me links (country code + number, no + or spaces)
NEXT_PUBLIC_WHATSAPP_PHONE="8618859725373"
# NUMBER: optional formatted display (e.g. in UI copy)
NEXT_PUBLIC_WHATSAPP_NUMBER="+86 188 5972 5373"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@primeluxr.com"
EMAIL_REPLY_TO="support@primeluxr.com"
# Dev only: skip verification emails and allow immediate login after register
SKIP_EMAIL_VERIFICATION="false"

# Payments (sandbox — Phase 7)
# Set to "true" to enable credit/debit card checkout via Midtrans (off by default)
NEXT_PUBLIC_ENABLE_CREDIT_CARD_PAYMENT="false"
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
# USD → IDR fallback if live rate API is down (storefront stays USD)
USD_TO_IDR_RATE="16500"
# Live rate via Frankfurter (free, no API key). Cache refreshes hourly.
# EXCHANGE_RATE_CACHE_SECONDS="3600"
# Force static rate only: EXCHANGE_RATE_PROVIDER="static"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

# Redis (Upstash — Phase 6+)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Storage (production image uploads — use one of the options below)
# Option A: Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
# Option B: Vercel Blob (Vercel dashboard → Storage → Blob). Auto-set on Vercel when linked.
# Required for product image uploads on Vercel unless Cloudflare R2 is configured.
BLOB_READ_WRITE_TOKEN=""
# If neither is set, local dev saves to /public/uploads; production requires R2, Blob, or paste image URL in admin.

# Payments — customer-facing merchant label on PayPal / Midtrans checkout
PAYMENT_MERCHANT_NAME="PrimeLuxr"

# Analytics
# Meta Pixel — Events Manager → Data sources → your pixel → Settings
NEXT_PUBLIC_META_PIXEL_ID=""
# Storefront pageview tracking (required for GA4)
NEXT_PUBLIC_GA_ID=""
# Optional: show GA4 summaries in /admin dashboard (requires Google Analytics Data API)
# 1. Create a GA4 property → copy Measurement ID into NEXT_PUBLIC_GA_ID
# 2. Admin → Property access → add a service account with Viewer role
# 3. Create a service account key (JSON) and map fields below
GA4_PROPERTY_ID=""
GA4_CLIENT_EMAIL=""
GA4_PRIVATE_KEY=""
NEXT_PUBLIC_CLARITY_ID=""

# Google Search Console site verification (meta tag method)
GOOGLE_SITE_VERIFICATION="854c868d465b316a"
